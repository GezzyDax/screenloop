SCREENLOOP_HTTP_PORT=8099
SCREENLOOP_BOOTSTRAP_USER=admin
SCREENLOOP_BOOTSTRAP_PASSWORD=change-this-to-a-long-random-password
SCREENLOOP_SECRET_KEY=change-this-to-a-long-random-secret
SCREENLOOP_ADVERTISE_HOST=
SCREENLOOP_ADVERTISE_HOSTS=
SCREENLOOP_MAX_UPLOAD_BYTES=2147483648
SCREENLOOP_SESSION_TTL_SECONDS=43200
SCREENLOOP_COOKIE_SECURE=false
SCREENLOOP_ACCESS_LOG=true

# Optional hardening for reverse proxies and TV network scope.
SCREENLOOP_PUBLIC_URL=
SCREENLOOP_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
SCREENLOOP_ALLOWED_TV_CIDRS=

# Local testing only. Do not enable in production or on shared LANs.
# SCREENLOOP_ALLOW_INSECURE_AUTH=true
